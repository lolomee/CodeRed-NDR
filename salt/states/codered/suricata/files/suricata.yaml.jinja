# CodeRed NDR - Suricata Configuration Overlay
# Auto-generated by Salt. Do not edit manually.
# This is merged with the default SO suricata.yaml.

%YAML 1.1
---

# Community ID for cross-tool correlation
{% if community_id == 'yes' %}
community-id: true
community-id-seed: 0
{% endif %}

# EVE JSON output configuration
outputs:
  - eve-log:
      enabled: yes
      filetype: regular
      filename: eve.json
      community-id: {{ 'true' if community_id == 'yes' else 'false' }}
      community-id-seed: 0
      types:
{% for etype in eve_types.split(',') %}
        - {{ etype.strip() }}:
            enabled: yes
{% endfor %}

# AF-Packet configuration (multi-interface support)
{% if ips_mode != 'yes' %}
{% set iface_list = monitor_interfaces.split(',') %}
af-packet:
{% for iface in iface_list %}
{% set iface = iface.strip() %}
  - interface: {{ iface }}
    threads: {{ threads }}
    cluster-id: {{ 99 + loop.index0 }}
    cluster-type: cluster_flow
    defrag: yes
    use-mmap: yes
    ring-size: 200000
    block-size: 262144
{% endfor %}
{% endif %}

# Performance tuning
detect:
  profile: high
  custom-values:
    toclient-groups: 200
    toserver-groups: 200
  sgh-mpm-context: auto
  inspection-recursion-limit: 3000

# Stream engine tuning
stream:
  memcap: 512mb
  reassembly:
    memcap: 256mb
    depth: 1mb
    toserver-chunk-size: 2560
    toclient-chunk-size: 2560
    randomize-chunk-size: yes

# Threading
threading:
  set-cpu-affinity: no
  detect-thread-ratio: 1.0
