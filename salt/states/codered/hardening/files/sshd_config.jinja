# CodeRed NDR - Hardened SSH Configuration
# Managed by Salt. Do not edit manually.

# Disable root login entirely
PermitRootLogin no

# Allow both key and password auth
PubkeyAuthentication yes
PasswordAuthentication yes

# Disable dangerous features
PermitEmptyPasswords no
X11Forwarding no
AllowTcpForwarding no
AllowAgentForwarding no
PermitTunnel no
GatewayPorts no

# Allow two users:
#   ubuntu     = admin (key-only, full bash + sudo)
#   coderedai  = customer (password, restricted CLI)
AllowUsers ubuntu coderedai

# Force key-only for ubuntu (no password login for admin)
Match User ubuntu
    PasswordAuthentication no
    PubkeyAuthentication yes

# Force password-only for coderedai (no key escape)
Match User coderedai
    PasswordAuthentication yes
    PubkeyAuthentication no

# Session limits
MaxAuthTries 3
MaxSessions 3
LoginGraceTime 30
ClientAliveInterval 300
ClientAliveCountMax 2

# Logging
LogLevel VERBOSE
SyslogFacility AUTH

# Use strong crypto
KexAlgorithms curve25519-sha256@libssh.org,diffie-hellman-group16-sha512,diffie-hellman-group18-sha512
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# SFTP - disabled for coderedai, allowed for ubuntu
Subsystem sftp /usr/lib/openssh/sftp-server

Match User coderedai
    ForceCommand /usr/bin/python3 /opt/codered/shell/cli.py
    AllowTcpForwarding no
    X11Forwarding no

# Banner
Banner /etc/ssh/codered-banner
