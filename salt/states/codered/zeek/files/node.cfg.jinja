# CodeRed NDR - Zeek Cluster Configuration
# Auto-generated by Salt. Do not edit manually.
# Supports multiple monitoring interfaces.

[logger]
type=logger
host=localhost

[manager]
type=manager
host=localhost

[proxy-1]
type=proxy
host=localhost

{% set iface_list = monitor_interfaces.split(',') %}
{% set workers_per_iface = (workers / iface_list|length) | int %}
{% set workers_per_iface = [workers_per_iface, 1] | max %}
{% set worker_id = [0] %}
{% for iface in iface_list %}
{% set iface = iface.strip() %}
{% for i in range(1, workers_per_iface + 1) %}
{% set _ = worker_id.append(worker_id[-1] + 1) %}
[worker-{{ worker_id[-1] }}]
type=worker
host=localhost
interface={{ iface }}
lb_method=pf_ring
lb_procs={{ workers_per_iface }}
{% endfor %}
{% endfor %}
