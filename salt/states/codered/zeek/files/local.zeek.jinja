# CodeRed NDR - Zeek Local Configuration
# Auto-generated by Salt. Do not edit manually.

# JSON output for structured log forwarding
@load policy/tuning/json-logs

# Community ID for cross-tool correlation (Suricata, Zeek, SIEM)
{% if community_id == 'yes' %}
@load policy/protocols/conn/community-id-logging
{% endif %}

# Protocol analyzers
{% set proto_list = protocols.split(',') %}
{% if 'dns' in proto_list %}
@load base/protocols/dns
{% endif %}
{% if 'http' in proto_list %}
@load base/protocols/http
@load policy/protocols/http/detect-sqli
@load policy/protocols/http/detect-webapps
{% endif %}
{% if 'ssl' in proto_list %}
@load base/protocols/ssl
@load policy/protocols/ssl/validate-certs
@load policy/protocols/ssl/log-hostcerts-only
@load policy/protocols/ssl/notary
{% endif %}
{% if 'smtp' in proto_list %}
@load base/protocols/smtp
{% endif %}
{% if 'ssh' in proto_list %}
@load base/protocols/ssh
@load policy/protocols/ssh/detect-bruteforcing
@load policy/protocols/ssh/geo-data
@load policy/protocols/ssh/interesting-hostnames
{% endif %}
{% if 'ftp' in proto_list %}
@load base/protocols/ftp
{% endif %}
{% if 'dhcp' in proto_list %}
@load base/protocols/dhcp
{% endif %}
{% if 'ntp' in proto_list %}
@load base/protocols/ntp
{% endif %}
{% if 'smb' in proto_list %}
@load base/protocols/smb
@load policy/protocols/smb/log-cmds
{% endif %}
{% if 'rdp' in proto_list %}
@load base/protocols/rdp
{% endif %}
{% if 'modbus' in proto_list %}
@load base/protocols/modbus
{% endif %}
{% if 'dnp3' in proto_list %}
@load base/protocols/dnp3
{% endif %}

# File extraction and hashing for threat hunting
@load frameworks/files/extract-all-files
@load policy/frameworks/files/hash-all-files

# Notice framework - generate notices for anomalous behavior
@load policy/misc/detect-traceroute
@load policy/misc/detect-MHR
@load policy/frameworks/notice/extend-email/hostnames

# Connection duration and data volume logging (important for UEBA)
redef Conn::Log::default_ext_logging = T;

# Intel framework for IOC matching
@load frameworks/intel/seen
@load frameworks/intel/do_notice
