# CodeRed NDR - Elastic Agent Additional Output
# Forwards Zeek + Suricata logs to external SIEM alongside SO's internal pipeline.

outputs:
  codered-siem:
    type: elasticsearch
    hosts:
      - "{{ protocol }}://{{ endpoint }}:{{ port }}"
    {% if token %}
    api_key: "{{ token }}"
    {% endif %}
    ssl:
      verification_mode: {{ 'full' if verify_ssl == 'yes' else 'none' }}
    index: "codered-sensor-%{[agent.type]}-%{+yyyy.MM.dd}"
    bulk_max_size: 2048
    worker: 2
    compression_level: 3

inputs:
  # Zeek JSON logs
  - type: filestream
    id: codered-zeek-logs
    paths:
      - /nsm/zeek/logs/current/*.log
    parsers:
      - ndjson:
          keys_under_root: true
          add_error_key: true
    fields:
      sensor.name: "{{ salt['pillar.get']('codered:sensor:name', 'unknown') }}"
      sensor.type: "zeek"
      event.module: "zeek"
    fields_under_root: false
    output: codered-siem

  # Suricata EVE JSON
  - type: filestream
    id: codered-suricata-eve
    paths:
      - /nsm/suricata/eve.json
    parsers:
      - ndjson:
          keys_under_root: true
          add_error_key: true
    fields:
      sensor.name: "{{ salt['pillar.get']('codered:sensor:name', 'unknown') }}"
      sensor.type: "suricata"
      event.module: "suricata"
    fields_under_root: false
    output: codered-siem

  # Wazuh alerts (optional)
  - type: filestream
    id: codered-wazuh-alerts
    paths:
      - /var/ossec/logs/alerts/alerts.json
    parsers:
      - ndjson:
          keys_under_root: true
          add_error_key: true
    fields:
      sensor.name: "{{ salt['pillar.get']('codered:sensor:name', 'unknown') }}"
      sensor.type: "wazuh"
      event.module: "wazuh"
    fields_under_root: false
    output: codered-siem
    ignore_inactive: since_last_start
