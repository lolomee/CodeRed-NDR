# CodeRed NDR - Instance Configuration Example
# Generated by first-boot wizard. Edit only via CLI or wizard.
# Copy to /etc/codered/sensor.conf — do not edit this example directly.

[sensor]
hostname = dc-sensor-01
sensor_name = datacenter-east-01

[network]
mgmt_interface = ens32
mgmt_mode = static
mgmt_ip = 10.50.1.100
mgmt_netmask = 255.255.255.0
mgmt_gateway = 10.50.1.1
mgmt_dns = 10.50.1.10,10.50.1.11
monitor_interface = ens34

# Deployment mode: 'no' = on-prem SPAN/TAP, 'yes' = cloud VXLAN (AWS/AliCloud/Azure)
cloud_mode = no
vxlan_port = 4789

[forwarding]
siem_output = elasticsearch
siem_host = siem.company.com
siem_port = 9200
# Transport security. Configure via CLI option 8 — see codered.defaults for
# the full list of TLS keys (siem_tls_verify, siem_tls_ca, siem_tls_servername,
# siem_tls_cert, siem_tls_key).
siem_tls = false
siem_tls_verify = true
siem_tls_ca =
siem_tls_servername =
siem_tls_cert =
siem_tls_key =
