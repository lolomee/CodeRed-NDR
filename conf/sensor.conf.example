# CodeRed NDR - Instance Configuration
# Generated by first-boot wizard. Edit only via the wizard or Salt.

[sensor]
hostname = dc-sensor-01
sensor_name = datacenter-east-01
registration_token = cr-tok-abc123def456

[network]
mgmt_interface = ens32
mgmt_mode = static
mgmt_ip = 10.50.1.100
mgmt_netmask = 255.255.255.0
mgmt_gateway = 10.50.1.1
mgmt_dns = 10.50.1.10,10.50.1.11
monitor_interface = ens34

[forwarding]
backend = elastic-agent
siem_endpoint = siem.company.com
siem_port = 9200
siem_protocol = https
siem_token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
siem_verify_ssl = yes
