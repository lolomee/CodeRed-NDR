#!/bin/bash
# /etc/profile.d/codered-cli.sh
# Launches the restricted CLI for the coderedai user only.
# The ubuntu user is unaffected (full bash + sudo for admin).

if [ "$(whoami)" = "coderedai" ]; then
    # Customer mode - restricted CLI, no bash escape
    logger -t codered-audit "coderedai login from ${SSH_CLIENT%% *:-console}"
    export PATH=""
    unset ENV BASH_ENV CDPATH GLOBIGNORE
    readonly HISTFILE=/dev/null
    set -r
    exec /usr/bin/python3 /opt/codered/shell/cli.py
    exit 0
fi
